{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--max-http-header-size=65536 vite dev --host 127.0.0.1",
    "dev:local": "node scripts/start-local-preview.mjs",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/accessibility.spec.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "bundle:audit": "node scripts/audit-bundle-size.mjs",
    "verify": "npm run test && npm run build && npm run bundle:audit",
    "format": "prettier --write .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \"scripts/**/*.{js,mjs,ts}\" package.json",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "scan:dependencies": "npm audit --omit=dev --audit-level=high",
    "migrate": "node run_migrations.mjs",
    "migrate:dry-run": "node run_migrations.mjs --dry-run",
    "migrate:seed": "node run_migrations.mjs --seed",
    "rls:bootstrap": "node src/test/rls/bootstrap-db.mjs",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "smoke:ephemeral-db": "node scripts/ephemeral-supabase-smoke.mjs",
    "smoke:ensure-ephemeral-db": "node scripts/ensure-ephemeral-db.mjs",
    "smoke:fresh-env": "node scripts/fresh-environment-smoke.mjs",
    "types:check": "node scripts/check-generated-types.mjs",
    "types:refresh": "node scripts/refresh-generated-types.mjs",
    "drift:check": "node scripts/check-schema-drift.mjs",
    "deploy:gate": "node scripts/deploy-gate.mjs",
    "confidence:full": "node scripts/full-environment-gate.mjs",
    "confidence:local": "node scripts/run-local-confidence.mjs",
    "schema:refresh-cache": "node scripts/refresh-schema-cache.mjs",
    "audit:verify-chains": "node scripts/verify-audit-chains.mjs",
    "audit:service-role": "node scripts/audit-service-role-usage.mjs",
    "audit:server-auth": "node scripts/audit-server-function-auth.mjs",
    "audit:idempotency": "node scripts/audit-idempotency.mjs",
    "audit:transactions": "node scripts/audit-transaction-boundaries.mjs",
    "audit:events": "node scripts/audit-event-coverage.mjs",
    "audit:indexes": "node scripts/audit-db-indexes.mjs",
    "audit:migrations": "node scripts/audit-migration-safety.mjs",
    "governance:enforce": "node scripts/enforce-data-governance.mjs",
    "governance:dry-run": "node scripts/enforce-data-governance.mjs --dry-run",
    "restore:drill": "node scripts/restore-staging-from-backup.mjs",
    "pilot:audit": "node scripts/audit-pilot-readiness.mjs",
    "pilot:gate": "node scripts/pilot-confidence-gate.mjs",
    "backend:audit": "node scripts/audit-backend-hardening.mjs && npm run audit:service-role && npm run audit:server-auth && npm run audit:idempotency && npm run audit:transactions && npm run audit:events && npm run audit:indexes && npm run load:tenant-scale",
    "env:validate": "node scripts/validate-env.mjs",
    "load:tenant-scale": "node scripts/tenant-scale-load.mjs",
    "load:tenant-db": "node scripts/tenant-db-concurrency-smoke.mjs",
    "worker:extraction": "node scripts/extraction-worker.mjs",
    "uploads:cleanup": "node scripts/cleanup-pending-document-uploads.mjs",
    "uploads:recover": "node scripts/recover-document-lifecycle.mjs",
    "permits:sources:check": "node scripts/review-permit-sources.mjs",
    "permits:sources:update": "node scripts/review-permit-sources.mjs --write",
    "demo:user": "node scripts/ensure-demo-user.mjs",
    "demo:user:local": "node scripts/run-with-local-supabase.mjs node scripts/ensure-demo-user.mjs",
    "sla:probe": "node scripts/sla-probe.mjs",
    "readiness:deployed": "node scripts/deployed-readiness-check.mjs",
    "ops:check": "node scripts/ops.mjs check",
    "ops:release": "node scripts/ops.mjs release",
    "ops:cleanup": "node scripts/ops.mjs cleanup",
    "ops:recover": "node scripts/ops.mjs recover"
  },
