# Deployment mode is authoritative. production/staging enforce the canonical
# staged upload + async worker lifecycle and require scanner/worker/telemetry.
AGIR_ENV=development
# Preferred server names. VITE_/NEXT_PUBLIC_ aliases remain only for existing
# host integrations; never place secrets in a browser-exposed variable.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
ANTHROPIC_API_KEY=
AGIR_AI_MODEL=claude-sonnet-4-6
# Optional. POST every server error (structured JSON) to this URL for monitoring
# (Sentry/Logflare/Axiom/Slack webhook). Unset = errors are still logged to
# stderr as `[agir-error] {...}` JSON, which a Vercel log drain can parse/alert on.
ERROR_WEBHOOK_URL=
# Optional. External anti-virus / content-scan endpoint. When set, uploaded
# documents are POSTed here before parsing; HTTP 200 = clean, 4xx = rejected.
# Infection verdicts carried in a 200 body are also honored: {clean:false},
# ClamAV-REST {"Status":"FOUND"}, {infected:true}, or a clamd "... FOUND" text
# line all hard-reject. Unset = structural scan only (signature/magic-byte,
# empty/oversize, disguised-binary). Production/staging always fail CLOSED on
# scanner outage; DOCUMENT_SCAN_FAIL_OPEN=1 is honored only in development/demo/test.
# See docs/security/document-av-scanning.md for a ready-to-run ClamAV setup.
DOCUMENT_SCAN_URL=
# Optional. Set to "multipart" for scanners expecting a multipart form upload
# (field "file"), e.g. clamav-rest containers. Default: raw bytes.
DOCUMENT_SCAN_FORMAT=
DOCUMENT_SCAN_FAIL_OPEN=
# Optional. Arms the schema-drift deploy gate (npm run drift:check / CI job):
# a read-capable URL to the prod/staging DB. Unset = the gate is a no-op.
SCHEMA_DRIFT_DATABASE_URL=
# Set to 1 to move document analysis (download, AV scan, OCR, AI)
# off the request path: analyzeDocument only enqueues an extraction_jobs row.
# It is forced on in staging/production and cannot be disabled there.
# and a worker executes it (npm run worker:extraction). Requires the worker to
# be running and EXTRACTION_WORKER_TOKEN set on both sides - see
# docs/ops/async-extraction.md. Unset/0 = analysis runs in-request (default).
EXTRACTION_ASYNC=
# Shared secret between the app's /api/extraction/worker endpoint and the
# worker process. The endpoint is disarmed (404) while this is unset.
EXTRACTION_WORKER_TOKEN=
# Worker-only: use a direct database URL and a protected HTTP handler.
WORKER_DATABASE_URL=
EXTRACTION_WORKER_HANDLER_URL=
# Counsel-reviewable Permit-mode limitation copy. Keep its approved version in
# src/lib/permit-limitations.ts aligned with each wording revision.
VITE_PERMIT_LIMITATIONS_TEXT=
# Global emergency control. Set to false to hide Permit mode while preserving data.
PERMITS_ENABLED=true
